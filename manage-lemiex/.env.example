APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000,127.0.0.1:5173,127.0.0.1:3000,localhost:5001
FRONTEND_URL=http://localhost:5173

# CORS Allowed Origins (comma separated)
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173,http://127.0.0.1:3000,http://localhost:5001"

# External Services
QR_SERVICE_URL=https://manage.lemiex.us/pes-api/qr/generate
QR_STORAGE_URL=https://s3.us-east-005.backblazeb2.com/Lemiex-Fulfillment/convert_qr
MERGE_IMAGE_SERVICE_URL=https://manage.lemiex.us/pes-api/merge-image
LABEL_CONVERT_SERVICE_URL=https://job3.pressify.us/api/convert-label-lemiux

# PES Conversion Service
PES_TO_JSON_SERVICE_URL=http://feline.ink/convert-pes-to-json
PES_TO_DST_SERVICE_URL=http://feline.ink/process

# Frontend Tracking URL (for QR codes)
FRONTEND_TRACKING_URL=https://your-frontend-domain.com

# HTTP Client Settings
# Set to false for local development, true for production
HTTP_VERIFY_SSL=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

JWT_SECRET=
JWT_TTL=43200
JWT_REFRESH_TTL=43200

# ShipEngine Configuration
SHIPENGINE_API_KEY=
SHIPENGINE_TEST_MODE=false
SHIPENGINE_TEST_CARRIER_ID=

# Telegram Bot Configuration (for alerts)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
